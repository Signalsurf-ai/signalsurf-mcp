# Supabase backend. Prefer the same values used by SignalsurfWeb.
SIGNALSURF_SUPABASE_URL=https://your-project-ref.supabase.co
SIGNALSURF_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# HTTP transport
SIGNALSURF_MCP_TRANSPORT=http
SIGNALSURF_MCP_AUTH_MODE=database
SIGNALSURF_MCP_HOST=127.0.0.1
SIGNALSURF_MCP_PORT=3333
SIGNALSURF_MCP_PATH=/mcp
# Set to true only behind a trusted proxy that overwrites X-Forwarded-For.
SIGNALSURF_MCP_TRUST_PROXY=false
# Comma-separated Host header allowlist for HTTP mode. Keep loopback defaults
# for local use; set your reverse-proxy hostname for hosted deployments.
# SIGNALSURF_MCP_ALLOWED_HOSTS=127.0.0.1,localhost,::1

# Static token entries are used only when SIGNALSURF_MCP_AUTH_MODE=env.
# Hosted production should use database auth and tokens created in SignalSurf Web.
# For local stdio or static-token HTTP development, set:
# SIGNALSURF_MCP_AUTH_MODE=env
# For env-token deployments, prefer tokenSha256 over token so plaintext secrets
# are not in env.
# Generate a hash with:
#   printf '%s' 'your-token' | shasum -a 256
SIGNALSURF_MCP_TOKENS='[
  {
    "name": "local-agent",
    "tokenSha256": "replace-with-sha256",
    "productId": "00000000-0000-0000-0000-000000000000",
    "userId": "00000000-0000-0000-0000-000000000000",
    "role": "editor"
  }
]'

# Stdio clients can either pass SIGNALSURF_MCP_TOKEN or use direct local context.
# Direct context is intended for local trusted stdio use only. Auth-disabled
# direct context is rejected for HTTP transport.
# SIGNALSURF_MCP_TOKEN=your-token
# SIGNALSURF_MCP_AUTH_DISABLED=false
# SIGNALSURF_MCP_PRODUCT_ID=00000000-0000-0000-0000-000000000000
# SIGNALSURF_MCP_USER_ID=00000000-0000-0000-0000-000000000000
# SIGNALSURF_MCP_ROLE=editor
